# Database
MYSQL_DATABASE=nutricash_ai
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=nutricash
MYSQL_PASSWORD=change_me_database_password
MYSQL_PORT=3307

# Published application ports
BACKEND_PORT=8081
FRONTEND_PORT=5174
PHPMYADMIN_PORT=8082

# Browser-facing API URL. VITE_* values are public; never put secrets here.
VITE_API_BASE_URL=http://localhost:8081

# Backend secrets and integrations (currently placeholders in the application)
JWT_SECRET=replace_with_a_secure_random_secret_of_at_least_32_characters
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AI_PROVIDER=GEMINI
AI_API_KEY=
AI_MODEL=gemini-2.5-flash-lite
AI_FALLBACK_MODEL=gemini-2.5-flash

# SMTP credentials
MAIL_USERNAME=
MAIL_PASSWORD=

# Development database settings
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# RabbitMQ / AI jobs
RABBITMQ_USER=nutriwallet
RABBITMQ_PASSWORD=nutriwallet_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
AI_JOBS_PER_SECOND=3
AI_RETRY_MAX_ATTEMPTS=3
AI_CACHE_TTL_DAYS=30
